# Copy this file to .env.development (for local dev) and .env.production (for local prod builds).
# Never commit either of those files — they are gitignored.
#
# Vercel reads its own env vars from the dashboard, not from these files.
# Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in:
#   Vercel → Project Settings → Environment Variables
#   - Production  → your prod Supabase project
#   - Preview     → your dev Supabase project

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
